{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "lastActive": { "type": "number" }
      },
      "required": ["uid", "email"]
    },
    "StockAnalysis": {
      "title": "Stock Analysis",
      "description": "SEPA analysis result for a single stock",
      "type": "object",
      "properties": {
        "ticker": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "change": { "type": "number" },
        "status": { "type": "string" },
        "score": { "type": "number" },
        "rsRank": { "type": "number" },
        "rsRating": { "type": "number" },
        "ma50": { "type": "number" },
        "ma150": { "type": "number" },
        "ma200": { "type": "number" },
        "low52w": { "type": "number" },
        "high52w": { "type": "number" },
        "trendTemplate": { "type": "boolean" },
        "volatility": { "type": "string" },
        "lastClose": { "type": "number" },
        "buyPoint": { "type": "number" },
        "buyRange": { "type": "string" },
        "stopLoss": { "type": "number" },
        "target1": { "type": "number" },
        "target2": { "type": "number" },
        "rsTrend": { "type": "string" },
        "pivotCreationDate": { "type": "string" },
        "suggestion": { "type": "string" }
      },
      "required": ["ticker", "price"]
    },
    "ScanMetadata": {
      "title": "Scan Metadata",
      "description": "Status and progress of a market scan",
      "type": "object",
      "properties": {
        "market": { "type": "string", "enum": ["TW", "US"] },
        "progress": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["idle", "scanning", "completed", "error"] },
        "lastScanTime": { "type": "number" }
      },
      "required": ["market", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/markets/{marketId}": {
      "schema": "ScanMetadata",
      "description": "Metadata for a specific market scan"
    },
    "/users/{userId}/markets/{marketId}/stocks/{ticker}": {
      "schema": "StockAnalysis",
      "description": "Individual stock analysis result"
    }
  }
}
