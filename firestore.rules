rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBALS & HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
        return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_.\\-]+$'); 
    }

    // ---------------------------------------------------------
    // VALIDATORS
    // ---------------------------------------------------------
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidScanMetadata(data) {
      return data.keys().hasAll(['market', 'status']) &&
             data.market in ['TW', 'US'] &&
             data.status in ['idle', 'scanning', 'completed', 'error'] &&
             (data.get('progress', 0) is number) &&
             (data.get('total', 0) is number);
    }

    function isValidStock(data) {
      return data.keys().hasAll(['ticker', 'price']) &&
             data.ticker is string && data.ticker.size() <= 16 &&
             data.price is number;
    }

    // ---------------------------------------------------------
    // DEFAULT DENY
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // COLLECTIONS
    // ---------------------------------------------------------
    
    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'lastActive', 'email']);
    }

    // Market Metadata
    match /users/{userId}/markets/{marketId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidScanMetadata(incoming()) && isValidId(marketId);
    }

    // Stocks Subcollection
    match /users/{userId}/markets/{marketId}/stocks/{ticker} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidStock(incoming()) && isValidId(marketId) && isValidId(ticker);
      allow delete: if isOwner(userId);
    }
  }
}
